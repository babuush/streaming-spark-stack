# Copy this file to .env before running `docker compose up -d`.
# These are LOCAL-DEV-ONLY defaults — do not reuse them anywhere else.

# Postgres (Airflow metadata DB)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# Airflow secrets (shared by api-server, scheduler, dag-processor)
AIRFLOW__API__SECRET_KEY=this_is_a_very_secured_key
AIRFLOW__API_AUTH__JWT_SECRET=shared_jwt_secret_for_local_dev_only

# Spark connection used by SparkSubmitOperator
AIRFLOW_CONN_SPARK_DEFAULT=spark://spark-master:7077
